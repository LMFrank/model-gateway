APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
GATEWAY_PORT=8080
GATEWAY_CONTAINER_NAME=model-gateway
GATEWAY_DOCKER_NETWORK=gateway_shared_net
KIMI_HOME_DIR=./runtime/kimi-home

GATEWAY_CLIENT_TOKEN=replace_with_client_token
GATEWAY_ADMIN_TOKEN=replace_with_admin_token

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=model_gateway_user
MYSQL_PASSWORD=replace_with_password
MYSQL_DATABASE=model_gateway
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=5

QWEN_TIMEOUT_SEC=120
KIMI_TIMEOUT_SEC=120
KIMI_CLI_CMD=kimi
